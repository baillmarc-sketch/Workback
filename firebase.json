{
  "hosting": {
    "public": "out",
    "cleanUrls": true,
    "ignore": ["**/.*"],
    "headers": [
      {
        "source": "/_next/static/**",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      },
      {
        "source": "**/*.html",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  },
  "emulators": {
    "database": { "host": "127.0.0.1", "port": 9000 },
    "ui": { "enabled": false },
    "singleProjectMode": true
  }
}
