{
  "rules": {
    ".read": false,
    ".write": false,
    "shared": {
      "$shareId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['id', 'events', 'updatedAt']) && newData.child('updatedAt').isNumber()"
      }
    },
    "sharedEstimates": {
      "$shareId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['id', 'updatedAt']) && newData.child('updatedAt').isNumber() && (!data.exists() || newData.child('updatedAt').val() >= data.child('updatedAt').val())"
      }
    },
    "sharedBidSpecs": {
      "$shareId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['id', 'updatedAt']) && newData.child('updatedAt').isNumber() && (!data.exists() || newData.child('updatedAt').val() >= data.child('updatedAt').val())"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "projects": {
          "$pid": {
            ".validate": "newData.hasChildren(['id', 'events', 'updatedAt'])"
          }
        },
        "deleted": {
          "$pid": {
            ".validate": "newData.isNumber()"
          }
        },
        "estimates": {
          "$eid": {
            ".validate": "newData.hasChildren(['id', 'updatedAt']) && (!data.exists() || !data.hasChild('updatedAt') || newData.child('updatedAt').val() >= data.child('updatedAt').val())"
          }
        },
        "estimatesDeleted": {
          "$eid": {
            ".validate": "newData.isNumber()"
          }
        },
        "bidSpecs": {
          "$sid": {
            ".validate": "newData.hasChildren(['id', 'updatedAt']) && (!data.exists() || !data.hasChild('updatedAt') || newData.child('updatedAt').val() >= data.child('updatedAt').val())"
          }
        },
        "bidSpecsDeleted": {
          "$sid": {
            ".validate": "newData.isNumber()"
          }
        }
      }
    }
  }
}
