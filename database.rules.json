{
  "rules": {
    ".read": false,
    ".write": false,

    "shared": {
      "$shareId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['id', 'events', 'updatedAt']) && newData.child('updatedAt').isNumber() && (!data.exists() || newData.child('updatedAt').val() >= data.child('updatedAt').val())"
      }
    },
    "sharedEstimates": {
      "$shareId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['id', 'updatedAt']) && newData.child('updatedAt').isNumber() && (!data.exists() || newData.child('updatedAt').val() >= data.child('updatedAt').val())"
      }
    },
    "sharedBidSpecs": {
      "$shareId": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['id', 'updatedAt']) && newData.child('updatedAt').isNumber() && (!data.exists() || newData.child('updatedAt').val() >= data.child('updatedAt').val())"
      }
    },

    "config": {
      "ownerUids": {
        ".read": "auth != null",
        "$uid": {
          ".write": "root.child('admins').child(auth.uid).exists()",
          ".validate": "newData.isBoolean()"
        }
      }
    },

    "admins": {
      ".read": "auth != null",
      "$uid": {
        ".write": "(root.child('admins').child(auth.uid).exists() || (auth.uid === $uid && (root.child('config').child('ownerUids').child(auth.uid).exists() || (auth.token.email != null && auth.token.email.toLowerCase() === 'baillmarc@gmail.com')))) && (newData.exists() || !root.child('config').child('ownerUids').child($uid).exists())",
        ".validate": "newData.isBoolean()"
      }
    },

    "registry": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".validate": "newData.hasChildren(['email', 'lastSeen'])",
        "email": { ".validate": "newData.isString() && newData.val() === auth.token.email" },
        "emailKey": { ".validate": "newData.isString()" },
        "name": { ".validate": "newData.isString() || newData.val() == null" },
        "photoURL": { ".validate": "newData.isString() || newData.val() == null" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "lastSeen": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },

    "entitlements": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "root.child('admins').child(auth.uid).exists()",
        "estimator": { ".validate": "newData.isBoolean()" },
        "estimatorViaTeam": { ".validate": "newData.isBoolean()" },
        "$other": { ".validate": false }
      }
    },

    "roles": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "root.child('admins').child(auth.uid).exists()",
        ".validate": "newData.isString() && (newData.val() == 'owner' || newData.val() == 'admin' || newData.val() == 'member')"
      }
    },

    "teams": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      ".write": "root.child('admins').child(auth.uid).exists()",
      "$teamId": {
        ".validate": "newData.hasChildren(['name'])",
        "name": { ".validate": "newData.isString()" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "members": {
          "$uid": { ".validate": "newData.isBoolean()" }
        },
        "apps": {
          "estimator": { ".validate": "newData.isBoolean()" },
          "$other": { ".validate": false }
        },
        "$other": { ".validate": false }
      }
    },

    "userTeams": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "root.child('admins').child(auth.uid).exists()",
        "$teamId": {
          ".validate": "newData.hasChildren(['name'])",
          "name": { ".validate": "newData.isString()" },
          "$other": { ".validate": false }
        }
      }
    },

    "teamWorkspaces": {
      "$teamId": {
        ".read": "auth != null && (root.child('teams').child($teamId).child('members').child(auth.uid).exists() || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (root.child('teams').child($teamId).child('members').child(auth.uid).exists() || root.child('admins').child(auth.uid).exists())",
        "docs": {
          "$appId": {
            "$docId": {
              ".validate": "newData.hasChildren(['id', 'updatedAt']) && newData.child('updatedAt').isNumber()"
            }
          }
        },
        "trash": {
          "$appId": {
            "$docId": {
              ".validate": "newData.hasChildren(['id', 'updatedAt']) && newData.child('updatedAt').isNumber()"
            }
          }
        },
        "presence": {
          "$appId": {
            "$docId": {
              "$sessionId": {
                ".validate": "newData.hasChildren(['name', 't']) && newData.child('t').isNumber() && newData.child('name').isString() && newData.child('name').val().length < 120",
                "name": { ".validate": "newData.isString()" },
                "t": { ".validate": "newData.isNumber()" },
                "$other": { ".validate": false }
              }
            }
          }
        }
      }
    },

    "invites": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      ".write": "root.child('admins').child(auth.uid).exists()",
      "$emailKey": {
        ".read": "auth != null && (root.child('admins').child(auth.uid).exists() || (root.child('registry').child(auth.uid).child('email').exists() && $emailKey === root.child('registry').child(auth.uid).child('email').val().toLowerCase().replace('.', ',').replace('.', ',').replace('.', ',').replace('.', ',').replace('.', ',').replace('.', ',')))",
        ".validate": "newData.hasChildren(['email'])",
        "email": { ".validate": "newData.isString()" },
        "estimator": { ".validate": "newData.isBoolean()" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "invitedBy": { ".validate": "newData.isString()" },
        "$other": { ".validate": false }
      }
    },

    "accessRequests": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".validate": "newData.hasChildren(['email', 'createdAt']) && newData.child('createdAt').isNumber()",
        "email": { ".validate": "newData.isString() && newData.val() === auth.token.email" },
        "name": { ".validate": "newData.isString() || newData.val() == null" },
        "message": { ".validate": "newData.isString() || newData.val() == null" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },

    "feedback": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      ".indexOn": ["createdAt"],
      "$id": {
        ".write": "(!data.exists() && newData.exists()) || root.child('admins').child(auth.uid).exists()",
        ".validate": "(newData.child('createdAt').isNumber() || data.child('createdAt').isNumber()) && (newData.child('message').isString() || data.child('message').isString())",
        "createdAt": { ".validate": "newData.isNumber()" },
        "kind": { ".validate": "newData.isString()" },
        "message": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 4000" },
        "email": { ".validate": "newData.isString() || newData.val() == null" },
        "name": { ".validate": "newData.isString() || newData.val() == null" },
        "uid": { ".validate": "newData.isString() || newData.val() == null" },
        "app": { ".validate": "newData.isString() || newData.val() == null" },
        "path": { ".validate": "newData.isString() || newData.val() == null" },
        "userAgent": { ".validate": "newData.isString() || newData.val() == null" },
        "viewport": { ".validate": "newData.isString() || newData.val() == null" },
        "appVersion": { ".validate": "newData.isString() || newData.val() == null" },
        "errors": { ".validate": "(newData.isString() && newData.val().length <= 8000) || newData.val() == null" },
        "screenshot": { ".validate": "(newData.isString() && newData.val().length <= 400000) || newData.val() == null" },
        "status": { ".validate": "newData.isString() || newData.val() == null" },
        "reviewedAt": { ".validate": "newData.isNumber() || newData.val() == null" },
        "reviewedBy": { ".validate": "newData.isString() || newData.val() == null" },
        "$other": { ".validate": false }
      }
    },

    "auditLog": {
      ".read": "root.child('admins').child(auth.uid).exists()",
      ".indexOn": ["ts"],
      "$entry": {
        ".write": "root.child('admins').child(auth.uid).exists() && !data.exists() && newData.exists()",
        ".validate": "newData.hasChildren(['ts', 'actorUid', 'action']) && newData.child('ts').isNumber() && newData.child('actorUid').val() === auth.uid && newData.child('action').isString()",
        "ts": { ".validate": "newData.isNumber()" },
        "actorUid": { ".validate": "newData.isString()" },
        "actorEmail": { ".validate": "newData.isString() || newData.val() == null" },
        "action": { ".validate": "newData.isString()" },
        "target": { ".validate": "newData.isString() || newData.val() == null" },
        "detail": { ".validate": "newData.isString() || newData.val() == null" },
        "$other": { ".validate": false }
      }
    },

    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).exists())",
        "projects": {
          "$pid": {
            ".validate": "newData.hasChildren(['id', 'events', 'updatedAt'])"
          }
        },
        "deleted": {
          "$pid": {
            ".validate": "newData.isNumber()"
          }
        },
        "projectsTrash": {
          "$pid": {
            ".validate": "newData.hasChildren(['id', 'events', 'updatedAt'])"
          }
        },
        "estimates": {
          "$eid": {
            ".validate": "newData.hasChildren(['id', 'updatedAt']) && (!data.exists() || !data.hasChild('updatedAt') || newData.child('updatedAt').val() >= data.child('updatedAt').val())"
          }
        },
        "estimatesDeleted": {
          "$eid": {
            ".validate": "newData.isNumber()"
          }
        },
        "estimatesTrash": {
          "$eid": {
            ".validate": "newData.hasChildren(['id', 'updatedAt'])"
          }
        },
        "bidSpecs": {
          "$sid": {
            ".validate": "newData.hasChildren(['id', 'updatedAt']) && (!data.exists() || !data.hasChild('updatedAt') || newData.child('updatedAt').val() >= data.child('updatedAt').val())"
          }
        },
        "bidSpecsDeleted": {
          "$sid": {
            ".validate": "newData.isNumber()"
          }
        },
        "bidSpecsTrash": {
          "$sid": {
            ".validate": "newData.hasChildren(['id', 'updatedAt'])"
          }
        }
      }
    }
  }
}
